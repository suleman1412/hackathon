# LLM Provider: opencode | gemini | ollama
LLM_PROVIDER=opencode

# OpenCode Zen (default provider, free models available)
# Get your key at https://opencode.ai/auth
LLM_API_KEY=your_opencode_zen_api_key_here
OPENCODE_MODEL=deepseek-v4-flash-free

# Gemini provider (alternative)
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Ollama provider (local, no key needed)
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# OpenRouteService API key (free at https://openrouteservice.org)
ORS_API_KEY=your_ors_api_key_here